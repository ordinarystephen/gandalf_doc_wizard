# Offline mode — prevents HuggingFace from making any outbound internet calls
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1

# Local testing (local-testing branch only)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI — no API key needed; uses DefaultAzureCredential (az login / managed identity)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
OPENAI_API_VERSION=2024-02-01  # Check Azure OpenAI docs for latest stable version

# Vision deployment — can be same as above if GPT-4o
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Optional: Azure Document Intelligence (only needed for scanned PDFs)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
