# -----------------------------------------------------------------------------
# Azure OpenAI via DefaultAzureCredential — REQUIRED on this branch (domino).
# No OpenAI API-key fallback exists; build_llm() and get_embeddings() raise
# RuntimeError if these aren't set.
# -----------------------------------------------------------------------------
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
OPENAI_API_VERSION=2025-04-01-preview

# Optional: some platforms (Domino proxy) inject the endpoint — omit if so.
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Vision deployment for image-table OCR (doc_qa/ingest/image_table.py).
# Usually the same chat deployment.
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
# Summarization truncation cap (characters, not tokens). Azure quota usually
# accommodates the full ~400000.
# SUMMARIZE_MAX_CHARS=400000

# MLflow tracking — only needed for the AICE deployment pattern on Domino.
# MLFLOW_TRACKING_URI=databricks
