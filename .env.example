# -----------------------------------------------------------------------------
# Local development — OpenAI fallback path
# -----------------------------------------------------------------------------
# Unset the AZURE_* vars below to force this path. Keep your real key out of
# this file — put it in .env (which is gitignored).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Work / Domino — Azure OpenAI via DefaultAzureCredential (no API key)
# -----------------------------------------------------------------------------
# Setting AZURE_OPENAI_DEPLOYMENT switches chain.build_llm() to AzureChatOpenAI
# with a bearer token from DefaultAzureCredential. Same toggle for embeddings
# via AZURE_EMBEDDING_DEPLOYMENT → AzureOpenAIEmbeddings.
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
OPENAI_API_VERSION=2025-04-01-preview

# Optional: some platforms (Domino proxy) inject the endpoint for you — omit
# this line if so. Set only when running against a direct Azure endpoint.
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Vision deployment for image-table OCR (doc_qa/ingest/image_table.py).
# Usually the same chat deployment.
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
# Summarization truncation cap (characters, not tokens). Default 100000 keeps
# OpenAI Tier 1 (30k TPM) safe; bump to ~400000 on Tier 2 / Azure.
# SUMMARIZE_MAX_CHARS=100000

# MLflow tracking — only needed for the AICE deployment pattern on Domino.
# MLFLOW_TRACKING_URI=databricks
